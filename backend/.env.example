# RescueLink backend — safe example (copy to backend/.env for local dev)
# Replace placeholders. Production secrets go in Render Dashboard only.

# =========================
# Django Core
# =========================

SECRET_KEY=your-django-secret-key
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_ADMIN_URL=admin/

# =========================
# Security / HTTPS
# =========================

SECURE_SSL_REDIRECT=
SECURE_HSTS_SECONDS=
SECURE_HSTS_INCLUDE_SUBDOMAINS=
SECURE_HSTS_PRELOAD=
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# =========================
# Database
# =========================

DATABASE_URL=
DB_HOST=db.your-project-ref.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-database-password
DB_SSLMODE=require

# =========================
# Supabase Storage
# =========================

SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_STORAGE_ENDPOINT=https://your-project-ref.storage.supabase.co/storage/v1/s3
SUPABASE_STORAGE_REGION=ap-northeast-1
SUPABASE_STORAGE_BUCKET=emergency-photos
SUPABASE_S3_ACCESS_KEY_ID=your-s3-access-key-id
SUPABASE_S3_SECRET_ACCESS_KEY=your-s3-secret-access-key

# =========================
# Email — Gmail SMTP (OTP)
# =========================
#
# IMPORTANT: Do NOT use your regular Gmail password here.
# You must use a Gmail App Password:
#   1. Enable 2-Step Verification on your Google account.
#   2. Visit https://myaccount.google.com/apppasswords
#   3. Create an App Password (select "Mail" + "Other (Custom name): RescueLink").
#   4. Paste the generated 16-character password as EMAIL_HOST_PASSWORD below.
#
# These two variables are the only Gmail credentials you need to set.
# Never commit real credentials to version control.

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=RescueLink <your-gmail@gmail.com>

# OTP settings (optional — defaults shown)
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=5
THROTTLE_OTP_REQUEST=5/hour
THROTTLE_OTP_VERIFY=10/hour

# =========================
# JWT
# =========================

JWT_ACCESS_TOKEN_HOURS=1
JWT_REFRESH_TOKEN_DAYS=7

# =========================
# API / Pagination / Throttling
# =========================

API_PAGE_SIZE=50
THROTTLE_ANON=60/hour
THROTTLE_USER=600/hour
THROTTLE_LOGIN=10/minute
THROTTLE_REGISTRATION=5/hour
THROTTLE_REPORT_CREATE=10/hour
THROTTLE_IMAGE_UPLOAD=20/hour
THROTTLE_STAFF_ACTION=120/hour
THROTTLE_ADMIN_ACTION=120/hour

# =========================
# OpenRouter AI
# =========================

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-120b:free
OPENROUTER_FALLBACK_MODEL=nvidia/nemotron-3-super:free
OPENROUTER_SAFETY_MODEL=nvidia/nemotron-3.5-content-safety:free
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_NAME=RescueLink
AI_PRIORITY_ENABLED=true
AI_ABUSE_DETECTION_ENABLED=true
AI_PRIORITY_TIMEOUT_SECONDS=10

# AI Provider ("openai" or "openrouter")
AI_PROVIDER=openai

# OpenAI settings
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
AI_PRIORITY_IMAGE_ANALYSIS=False
AI_PRIORITY_FALLBACK_RULES=True
AI_PRIORITY_AUTO_DISPATCH=False

AI_REVIEW_THRESHOLD=70
AI_AUTO_SUSPEND_THRESHOLD=90

# =========================
# Upload Limits
# =========================

MAX_EMERGENCY_PHOTO_BYTES=5242880
MAX_EMERGENCY_PHOTOS=5

# Local development examples:
# DEBUG=True
# ALLOWED_HOSTS=127.0.0.1,localhost
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# OPENROUTER_SITE_URL=http://localhost:5173
#
# Production (Render) examples:
# SECRET_KEY=<SECRET_KEY>
# DEBUG=False
# ALLOWED_HOSTS=<render-backend-hostname>
# DATABASE_URL=<DATABASE_URL>
# CORS_ALLOWED_ORIGINS=https://<vercel-frontend-domain>
# CSRF_TRUSTED_ORIGINS=https://<vercel-frontend-domain>
# SECURE_SSL_REDIRECT=True
# EMAIL_HOST_USER=<your-gmail>
# EMAIL_HOST_PASSWORD=<your-gmail-app-password>
# DEFAULT_FROM_EMAIL=RescueLink <<your-gmail>>
